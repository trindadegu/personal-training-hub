{
  "builds": [
    {
      "src": "dist/server/server.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["dist/client/**"] }
    },
    {
      "src": "dist/client/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "dist/server/server.js" }
  ]
}